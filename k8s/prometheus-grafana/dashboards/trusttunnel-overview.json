      "id": 100,
      "title": "Client Sessions",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Active Sessions — HTTP/1.1",
      "description": "client_sessions{protocol_type=\"HTTP1\"} — concurrent HTTP/1.1 tunnels",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "client_sessions{job=\"trusttunnel-vpn\", protocol_type=\"HTTP1\"}",
          "legendFormat": "HTTP/1.1",
          "refId": "A"
        }
      ]
    },
