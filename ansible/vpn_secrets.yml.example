# Copy this file to vpn_secrets.yml and fill in real values.
# vpn_secrets.yml is GIT-IGNORED — never commit real credentials.
#
#   cp vpn_secrets.yml.example vpn_secrets.yml

# VPN client credentials
trusttunnel_client_username: "alice"
trusttunnel_client_password: "replace-with-a-strong-password"

# Cloudflare — for automated DNS record creation
# Zone ID: Cloudflare dashboard → your domain → Overview → Zone ID (right sidebar)
cloudflare_zone_id: "your-zone-id-here"
# API Token: Cloudflare → My Profile → API Tokens → Create Token
# Permissions needed: Zone:DNS:Edit + Zone:Zone:Read (specific zone only)
cloudflare_api_token: "your-api-token-here"